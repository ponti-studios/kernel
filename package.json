{
  "name": "@hackefeller/jinn",
  "version": "0.0.1",
  "description": "AI-powered assistant for all personal computing tasks",
  "keywords": [
    "agent",
    "ai",
    "assistant",
    "automation",
    "personal-computing"
  ],
  "homepage": "https://github.com/hackefeller/jinn#readme",
  "bugs": {
    "url": "https://github.com/hackefeller/jinn/issues"
  },
  "license": "SUL-1.0",
  "author": "Charles Ponti",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hackefeller/jinn.git"
  },
  "bin": {
    "jinn": "./dist/jinn"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "generate:template-refs": "bun ./src/templates/.generated/generate.ts",
    "build": "bun run generate:template-refs && bun build ./src/cli/main.ts --compile --outfile ./dist/jinn",
    "build:bin": "bun run generate:template-refs && bun build ./src/cli/main.ts --compile --outfile ./dist/jinn",
    "build:dev": "bun run generate:template-refs && bun build ./src/cli/main.ts --compile --outfile ./dist/jinn-dev",
    "dev:cli": "bun ./src/cli/main.ts",
    "link:dev": "ln -sf $PWD/dist/jinn-dev /usr/local/bin/jinn-dev",
    "test": "bun run generate:template-refs && bun test",
    "test:vault": "bun test src/core/vault/__tests__",
    "typecheck": "bun run generate:template-refs && bun --bun tsc --noEmit",
    "lefthook": "lefthook",
    "prepare": "lefthook install"
  },
  "release": {
    "branches": ["main"],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog"
    ]
  },
  "dependencies": {
    "commander": "^14.0.2",
    "yaml": "^2.8.0",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "bun-types": "latest",
    "knip": "^5.85.0",
    "lefthook": "^2.1.4",
    "oxlint": "^1.50.0",
    "semantic-release": "^25.0.3",
    "typescript": "^5.7.3"
  }
}
