{
  "name": "@hackefeller/kernel",
  "version": "0.0.5",
  "description": "Local brain and workflow OS for coding agents.",
  "keywords": [
    "agent",
    "ai",
    "assistant",
    "automation",
    "personal-computing"
  ],
  "homepage": "https://github.com/hackefeller/kernel#readme",
  "bugs": {
    "url": "https://github.com/hackefeller/kernel/issues"
  },
  "license": "SUL-1.0",
  "author": "Charles Ponti",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hackefeller/kernel.git"
  },
  "bin": {
    "kernel": "./dist/kernel"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "bun build ./src/cli/main.ts --compile --outfile ./dist/kernel && cp ./package.json ./dist/",
    "build:bin": "bun build ./src/cli/main.ts --compile --outfile ./dist/kernel && cp ./package.json ./dist/",
    "build:dev": "bun build ./src/cli/main.ts --compile --outfile ./dist/kernel-dev && cp ./package.json ./dist/",
    "dev:cli": "bun ./src/cli/main.ts",
    "link:dev": "ln -sf $PWD/dist/kernel-dev /usr/local/bin/kernel-dev",
    "test": "bun test",
    "test:vault": "bun test src/core/vault/__tests__",
    "typecheck": "bun --bun tsc --noEmit",
    "lefthook": "lefthook",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "yaml": "^2.8.0",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@changesets/cli": "^2.30.0",
    "bun-types": "latest",
    "knip": "^5.85.0",
    "lefthook": "^2.1.4",
    "oxlint": "^1.50.0",
    "typescript": "^5.7.3"
  }
}
