# Dependencies
.openspec-repo
node_modules/

# Build output
dist/

# Platform binaries (built, not committed)
packages/*/bin/jinn
packages/*/bin/jinn.exe
# Block ALL binaries in packages bin directories
packages/*/bin/*
!packages/*/bin/.gitkeep

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Temporary files
.tmp/
.worktrees/

# Lock files (use bun.lockb instead)
package-lock.json
yarn.lock

# Environment
.env
.env.local
test-injection/
notepad.md
oauth-success.html
.opencode-export
